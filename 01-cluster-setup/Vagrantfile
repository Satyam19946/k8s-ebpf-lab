# -*- mode: ruby -*-
# vi: set ft=ruby :

# Cluster node definitions — edit these to change the topology
NODES = [
  { name: "ctrl",    role: "control-plane", ip: "192.168.56.10", cpus: 2, mem: 2048 },
  { name: "worker1", role: "worker",        ip: "192.168.56.11", cpus: 2, mem: 2048 },
  { name: "worker2", role: "worker",        ip: "192.168.56.12", cpus: 2, mem: 2048 },
]

Vagrant.configure("2") do |config|

  # Use Ubuntu 24.04 LTS — same kernel as your host
  config.vm.box = "bento/ubuntu-24.04"

  # Use libvirt as the hypervisor (KVM/QEMU under the hood)
  config.vm.provider :libvirt do |libvirt|
    libvirt.driver = "kvm"
    libvirt.storage_pool_name = "default"
  end

  NODES.each do |node|
    config.vm.define node[:name] do |vm_config|

      vm_config.vm.hostname = node[:name]

      # Private network — all nodes on same subnet, static IPs
      # This is the network pods will route over
      vm_config.vm.network :private_network,
        ip: node[:ip],
        libvirt__network_name: "k8s-lab",
        libvirt__dhcp_enabled: false

      vm_config.vm.provider :libvirt do |libvirt|
        libvirt.cpus   = node[:cpus]
        libvirt.memory = node[:mem]
      end

      # Common provisioning for ALL nodes
      vm_config.vm.provision "shell", inline: <<-SHELL
        set -e

        echo "==> Disabling swap (kubelet requires this)"
        swapoff -a
        sed -i '/swap/d' /etc/fstab

        echo "==> Loading required kernel modules"
        modprobe overlay
        modprobe br_netfilter
        cat <<MODULES > /etc/modules-load.d/k8s.conf
overlay
br_netfilter
MODULES

        echo "==> Setting kernel networking parameters"
        cat <<SYSCTL > /etc/sysctl.d/k8s.conf
net.bridge.bridge-nf-call-iptables  = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward                 = 1
SYSCTL
        sysctl --system

        echo "==> Installing containerd"
        apt-get update -qq
        apt-get install -y -qq ca-certificates curl gnupg

        install -m 0755 -d /etc/apt/keyrings
        curl -fsSL https://download.docker.com/linux/ubuntu/gpg | \
          gpg --dearmor -o /etc/apt/keyrings/docker.gpg
        chmod a+r /etc/apt/keyrings/docker.gpg

        echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/docker.gpg] \
          https://download.docker.com/linux/ubuntu noble stable" | \
          tee /etc/apt/sources.list.d/docker.list

        apt-get update -qq
        apt-get install -y -qq containerd.io

        echo "==> Configuring containerd to use systemd cgroup driver"
        containerd config default | tee /etc/containerd/config.toml
        sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' \
          /etc/containerd/config.toml
        systemctl restart containerd
        systemctl enable containerd

        echo "==> Installing kubeadm, kubelet, kubectl"
        curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.31/deb/Release.key | \
          gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg

        echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] \
          https://pkgs.k8s.io/core:/stable:/v1.31/deb/ /" | \
          tee /etc/apt/sources.list.d/kubernetes.list

        apt-get update -qq
        apt-get install -y -qq kubelet kubeadm kubectl
        apt-mark hold kubelet kubeadm kubectl

        echo "==> Configuring kubelet node IP"
        echo "KUBELET_EXTRA_ARGS=--node-ip=#{node[:ip]}" > \
          /etc/default/kubelet
        systemctl enable kubelet

        echo "==> Node #{node[:name]} base provisioning complete"
      SHELL

    end
  end
end
